{
  "name": "server",
  "version": "1.0.0",
  "type": "commonjs",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun --inspect --watch src/index.ts",
    "build": "tsc --outDir dist",
    "start": "node dist/server/src/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "17.2.1",
    "express": "5.1.0",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/express": "5.0.3",
    "tsx": "4.20.4",
    "typescript": "5.9.2"
  },
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "outDir": "dist",
    "format": [
      "esm",
      "cjs"
    ],
    "target": "es2020",
    "skipNodeModulesBundle": true
  }
}
