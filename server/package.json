{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.ts",
  "scripts": {
    "dev": "node --import=tsx --watch src/index.ts",
    "build": "tsc --outDir dist",
    "start": "node dist/server/src/index.js"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "7.3.4",
    "cors": "2.8.5",
    "dotenv": "17.2.1",
    "express": "5.1.0",
    "express-rate-limit": "8.0.1",
    "helmet": "8.1.0",
    "http-status-codes": "2.3.0",
    "pino": "9.9.0",
    "pino-http": "10.5.0",
    "socket.io": "^4.8.1",
    "swagger-ui-express": "5.0.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.3",
    "tsx": "4.20.4",
    "typescript": "5.9.2"
  },
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "outDir": "dist",
    "format": [
      "esm",
      "cjs"
    ],
    "target": "es2020",
    "sourcemap": true,
    "clean": true,
    "dts": true,
    "splitting": false,
    "skipNodeModulesBundle": true
  }
}
